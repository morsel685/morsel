# Server Configuration
PORT=
NODE_ENV=

# Database Configuration
MONGODB_URI=""

# JWT Secret (You can change this to any random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Razorpay Configuration (Optional - needed only for payment features)
# Get these from https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Email Configuration (Required for email verification)
# For Gmail: Enable 2-factor authentication, then create an "App Password"
# Go to: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=

# Admin Email (Where to send employee approval requests)
# If not set, will use EMAIL_USER as admin email
ADMIN_EMAIL=

# Frontend Configuration
FRONTEND_URL=
RESTAURANT_NAME=